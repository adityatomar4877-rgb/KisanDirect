EXPO_PUBLIC_DATA_GOV_API_KEY=579b464db66ec23bdd0000015d3593a1f5e9409c482647496009769d

# Crop / Commodity Price APIs (Agmarknet — data.gov.in)
# Daily Wholesale Price: Agmarknet Commodity Prices
DATA_GOV_CROP_PRICE_RESOURCE_ID=9ef84268-d588-465a-a308-a864a43d0070

# Farmer's market (Mandi) prices
DATA_GOV_MANDI_PRICE_RESOURCE_ID=35985678-0d79-46b4-9ed6-6f13308a1d24

# ----------------------------------------------------------
#  API Base URL
# ----------------------------------------------------------
DATA_GOV_IN_BASE_URL=https://api.data.gov.in/resource

# ----------------------------------------------------------
#  App Config
# ----------------------------------------------------------
APP_ENV=development
# Options: development | staging | production

# Default state/district for price lookups (edit as needed)
DEFAULT_STATE=Madhya Pradesh
DEFAULT_DISTRICT=Gwalior